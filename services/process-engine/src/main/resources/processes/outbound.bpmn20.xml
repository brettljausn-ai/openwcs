<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://openwcs.org/processes">
  <!--
    Sample outbound process (build.md §7): release the order for fulfilment, wait for an operator
    to confirm the pick/pack (a user task), then dispatch the conveyor move. Demonstrates service
    tasks (releaseOrder, dispatchDeviceTask) and a user/wait task in one flow.
  -->
  <process id="outbound" name="Outbound" isExecutable="true">
    <startEvent id="start"/>
    <sequenceFlow id="f1" sourceRef="start" targetRef="release"/>
    <serviceTask id="release" name="Release order for allocation"
                 flowable:delegateExpression="${releaseOrder}"/>
    <sequenceFlow id="f2" sourceRef="release" targetRef="confirm"/>
    <userTask id="confirm" name="Confirm pick complete"/>
    <sequenceFlow id="f3" sourceRef="confirm" targetRef="dispatch"/>
    <serviceTask id="dispatch" name="Dispatch conveyor move"
                 flowable:delegateExpression="${dispatchDeviceTask}"/>
    <sequenceFlow id="f4" sourceRef="dispatch" targetRef="end"/>
    <endEvent id="end"/>
  </process>
</definitions>
