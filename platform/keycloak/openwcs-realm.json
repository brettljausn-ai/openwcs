{
  "realm": "openwcs",
  "enabled": true,
  "displayName": "openWCS",
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 3600,
  "roles": {
    "realm": [
      { "name": "ADMIN", "description": "Full access, including user/role administration" },
      { "name": "SUPERVISOR", "description": "Operations management" },
      { "name": "OPERATOR", "description": "Floor operations" },
      { "name": "VIEWER", "description": "Read-only access" }
    ]
  },
  "clients": [
    {
      "clientId": "openwcs-web",
      "name": "openWCS SPA / API client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    },
    {
      "clientId": "openwcs-iam",
      "name": "openWCS IAM service (self-service password change)",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "openwcs-iam-dev-secret",
      "redirectUris": [],
      "webOrigins": []
    }
  ],
  "users": [
    {
      "username": "service-account-openwcs-iam",
      "enabled": true,
      "serviceAccountClientId": "openwcs-iam",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users", "query-users"]
      }
    },
    {
      "username": "admin",
      "enabled": true,
      "firstName": "Ada",
      "lastName": "Admin",
      "email": "admin@example.com",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "admIn1!", "temporary": false }],
      "realmRoles": ["ADMIN"],
      "clientRoles": {
        "realm-management": ["manage-users", "view-users", "query-users", "query-groups", "view-realm"]
      }
    },
    {
      "username": "supervisor",
      "enabled": true,
      "firstName": "Sam",
      "lastName": "Supervisor",
      "email": "supervisor@example.com",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "supervisor", "temporary": false }],
      "realmRoles": ["SUPERVISOR"]
    },
    {
      "username": "operator",
      "enabled": true,
      "firstName": "Olive",
      "lastName": "Operator",
      "email": "operator@example.com",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "operator", "temporary": false }],
      "realmRoles": ["OPERATOR"]
    },
    {
      "username": "viewer",
      "enabled": true,
      "firstName": "Vera",
      "lastName": "Viewer",
      "email": "viewer@example.com",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "viewer", "temporary": false }],
      "realmRoles": ["VIEWER"]
    }
  ]
}
