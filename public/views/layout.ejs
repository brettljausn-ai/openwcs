<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
<%- headMeta %>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;1,600&family=DM+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="styles.css" />
  <script defer src="i18n.js"></script>
</head>
<body id="<%= typeof bodyId !== 'undefined' ? bodyId : 'top' %>">
  <header class="nav">
    <div class="nav-inner">
      <a class="brand" href="index.html"><img class="brand-logo" src="Logo_white_solo.png" width="359" height="82" alt="openWCS" /></a>
      <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Toggle menu" aria-expanded="false"><span class="bars" aria-hidden="true"></span></button>
      <nav class="nav-links"><%- typeof navLinks !== 'undefined' ? navLinks : '' %></nav>
      <div class="nav-right">
        <div class="lang" id="lang">
          <button class="lang-toggle" id="lang-toggle" type="button" aria-haspopup="listbox" aria-expanded="false" aria-label="Select language">
            <svg class="globe" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3c2.6 2.7 2.6 15.3 0 18M12 3c-2.6 2.7-2.6 15.3 0 18"/></svg>
            <span class="lang-code" id="lang-code">EN</span>
            <svg class="chev" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <ul class="lang-menu" id="lang-menu" role="listbox" aria-label="Language">
            <li role="option" data-lang="en"><span>English</span></li>
            <li role="option" data-lang="de"><span>Deutsch</span></li>
            <li role="option" data-lang="fr"><span>Français</span></li>
            <li role="option" data-lang="es"><span>Español</span></li>
          </ul>
        </div>
        <a class="btn btn-primary btn-nav" href="https://github.com/brettljausn-ai/openwcs" data-i18n="btnGitHubNav">GitHub</a>
        <a class="btn btn-ghost btn-nav" href="https://www.patreon.com/c/karlfriesenbichler" data-i18n="btnPatreon">Patreon</a>
      </div>
    </div>
  </header>

<%- body %>

  <footer>
    <div class="wrap">
      <span data-i18n="footerTag">openWCS — open-source Warehouse Control System · AGPL-3.0.</span>
      <span><a href="https://github.com/brettljausn-ai/openwcs">GitHub</a> · <a href="https://github.com/brettljausn-ai/openwcs/wiki">Docs</a> · <a href="https://www.patreon.com/c/karlfriesenbichler">Sponsor</a></span>
    </div>
  </footer>
<%- typeof scripts !== 'undefined' ? scripts : '' %>
</body>
</html>
