# openWCS public site — environment variables.
#
# NOTE: server.js does NOT load dotenv; the host (Hostinger / Render / etc.)
# injects these into the process environment. This file only documents them.
# Copy/adapt the names below into your host's env settings.

# Port the Express app listens on. The host usually assigns this automatically.
# PORT=3000

# --- Contact form (Microsoft Graph) -----------------------------------------
# Used by POST /api/contact to send contact-form mail via the Microsoft Graph
# client-credentials flow. The form silently returns 503 until all four
# required vars below are set.

# Azure AD tenant id (required)
MS_GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
# App registration client (application) id (required)
MS_GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
# App registration client secret (required) — keep this secret, never commit it
MS_GRAPH_CLIENT_SECRET=your-client-secret
# Mailbox the app sends as; the app registration must have Mail.Send for it (required)
MS_GRAPH_MAIL_ADDRESS=noreply@yourdomain.com
# Display name shown on the "from" address (optional, default: openWCS)
MS_GRAPH_FROM_NAME=openWCS
# Where contact submissions are delivered (optional, default: contact@brettljausn.ai)
CONTACT_TO=contact@brettljausn.ai
